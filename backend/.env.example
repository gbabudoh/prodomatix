# Copy this file to .env and adjust for your machine.

# API
PORT=4000
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
FREE_DOWNLOAD_CREDITS=3

# Google OAuth — "Sign in with Google".
# Create an OAuth 2.0 Client ID (type: Web application) in Google Cloud Console:
#   https://console.cloud.google.com/apis/credentials
# Add http://localhost:5173 to "Authorized JavaScript origins".
# This MUST be the same Client ID set as VITE_GOOGLE_CLIENT_ID in the frontend.
GOOGLE_CLIENT_ID=

# PostgreSQL — Prisma uses DATABASE_URL.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prodomatix?schema=public
DB_SSL=false

# Discrete parts (used as a fallback by the app if DATABASE_URL is empty)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=prodomatix

# Seed admin account (created by `npm run db:seed`)
SEED_ADMIN_EMAIL=admin@prodomatix.com
SEED_ADMIN_PASSWORD=admin12345
SEED_ADMIN_NAME=Platform Admin

# Seed demo user account (created by `npm run db:seed`)
SEED_DEMO_EMAIL=demo@prodomatix.com
SEED_DEMO_PASSWORD=demo12345
SEED_DEMO_NAME=Demo User
