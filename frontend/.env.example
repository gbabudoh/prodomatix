# Copy this file to .env (or .env.local) and restart `npm run dev`.

# Google OAuth — "Sign in with Google".
# Use the SAME OAuth 2.0 Web Client ID you set as GOOGLE_CLIENT_ID in the backend.
# Create it at https://console.cloud.google.com/apis/credentials and add
# http://localhost:5173 under "Authorized JavaScript origins".
# Leave blank to hide the Google button entirely.
VITE_GOOGLE_CLIENT_ID=

# Google Analytics (GA4) — the Measurement ID from your GA4 property,
# format "G-XXXXXXXXXX" (Admin → Data Streams → your web stream).
# Only loads for visitors who accept analytics cookies in the cookie banner,
# and never on /admin pages. Leave blank to disable analytics entirely.
VITE_GA_MEASUREMENT_ID=

# Microsoft Clarity project ID (session recording / heatmaps).
# Find it at https://clarity.microsoft.com under Settings → Setup.
# Same consent gating as GA above. Leave blank to disable entirely.
VITE_CLARITY_PROJECT_ID=

# Matomo — self-hosted analytics. URL must end with a trailing slash.
# Same consent gating as GA above. Leave either blank to disable entirely.
VITE_MATOMO_URL=
VITE_MATOMO_SITE_ID=
